{
  "name": "acp-chat",
  "version": "0.2.10",
  "description": "ACP Chat — agent-to-agent dialogue over TCP/Unix socket using the ACP protocol.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "url": "https://github.com/morozow/acp-chat",
    "type": "git"
  },
  "bin": {
    "acp-chat": "dist/cli.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "build:dev": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "acp",
    "agent",
    "chat",
    "stdio-bus",
    "json-rpc"
  ],
  "license": "Apache-2.0",
  "author": "Raman Marozau <raman@worktif.com>",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  }
}
